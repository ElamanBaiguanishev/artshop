# Скопировать в .env и заполнить. .env в git не попадает.

# --- база и кеш ---
# порты нестандартные, чтобы не конфликтовать с локальными postgres/redis
DATABASE_URL=postgres://artshop:artshop@localhost:5433/artshop
REDIS_URL=redis://localhost:6380

# --- хранилище (minio локально, S3-совместимое в проде) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=artshop-media
S3_ACCESS_KEY=artshop
S3_SECRET_KEY=artshop123
# базовый URL для отдачи файлов наружу
S3_PUBLIC_URL=http://localhost:9000/artshop-media

# --- сервисы ---
API_PORT=3001
WORKER_PORT=3002
CHAT_GATEWAY_PORT=3003
WEB_PORT=3000

# публичный адрес API для фронта
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- авторизация админки ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- telegram bot ---
# токен от @BotFather. Для локальной разработки завести ОТДЕЛЬНОГО бота,
# не того, что пойдёт в прод.
TELEGRAM_BOT_TOKEN=
# секретный сегмент пути вебхука + заголовок, который Telegram вернёт обратно
TELEGRAM_WEBHOOK_SECRET=
# публичный адрес chat-gateway для регистрации вебхука (в разработке - туннель)
TELEGRAM_WEBHOOK_URL=
# режим получения обновлений: webhook | polling (polling только для локальной разработки)
TELEGRAM_MODE=polling
